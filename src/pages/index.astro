  .carousel-btn {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    color: var(--text-color);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    font-size: 1.2rem;
  }

  .carousel-btn:hover {
    background: var(--brand-color);
    color: white;
    border-color: var(--brand-color);
    transform: scale(1.1);
  }

  .section-subtitle {
    opacity: 0.7;
    margin-bottom: 2rem;
  }
</style>

<script>
  // Carousel Navigation Logic
  const track = document.getElementById('articles-carousel') as HTMLElement;
  const prevBtn = document.querySelector('.carousel-btn.prev') as HTMLButtonElement;
  const nextBtn = document.querySelector('.carousel-btn.next') as HTMLButtonElement;

  if (track && prevBtn && nextBtn) {
    const getScrollAmount = () => {
      const itemWidth = track.querySelector('.carousel-item')?.getBoundingClientRect().width || 0;
      const gap = 24; // 1.5rem
      return itemWidth + gap;
    };

    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });

    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    // Optional: Hide arrows if at start/end
    track.addEventListener('scroll', () => {
      const maxScroll = track.scrollWidth - track.clientWidth;
      prevBtn.style.opacity = track.scrollLeft <= 5 ? '0.3' : '1';
      prevBtn.style.pointerEvents = track.scrollLeft <= 5 ? 'none' : 'auto';
      
      nextBtn.style.opacity = track.scrollLeft >= maxScroll - 5 ? '0.3' : '1';
      nextBtn.style.pointerEvents = track.scrollLeft >= maxScroll - 5 ? 'none' : 'auto';
    });
    
    // Initial state
    setTimeout(() => {
        track.dispatchEvent(new Event('scroll'));
    }, 100);
  }
</script>

