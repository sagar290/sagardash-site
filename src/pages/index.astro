---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Content as AboutContent } from '../content/about.md';
import Parser from 'rss-parser';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allExperience = await getCollection('experience');
const sortedExperience = allExperience.sort((a, b) => a.data.order - b.data.order);
// Render markdown content for experience highlights
const experienceWithContent = await Promise.all(
  sortedExperience.map(async (entry) => {
    const { Content } = await entry.render();
    return { ...entry, Content };
  })
);

const allSkills = await getCollection('skills');
const sortedSkills = allSkills.sort((a, b) => a.data.order - b.data.order);

const allOpenSource = await getCollection('opensource');
const sortedOpenSource = allOpenSource.sort((a, b) => a.data.order - b.data.order);

// Fetch Articles
const localArticles = await getCollection('articles');
const MEDIUM_RSS_URL = 'https://medium.com/feed/@sagar-dash290';
const parser = new Parser();
let mediumArticles = [];

try {
  const feed = await parser.parseURL(MEDIUM_RSS_URL);
  mediumArticles = feed.items.map(item => {
    const wordCount = item['content:encoded']?.split(/\s+/).length || 0;
    const readingTime = Math.ceil(wordCount / 200) || 1;
    return {
      title: item.title,
      link: item.link,
      date: new Date(item.pubDate!),
      readingTime: `${readingTime} min read`,
      source: 'Medium'
    };
  });
} catch (error) {
  console.warn("Could not fetch medium articles during build.");
}

const allArticles = [
  ...localArticles.map(a => ({
    title: a.data.title,
    link: a.data.link || `/articles/${a.slug}`,
    date: a.data.date,
    readingTime: 'Local',
    source: 'Local'
  })),
  ...mediumArticles
].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<BaseLayout title="Sagar Dash | Senior Software Engineer">
  <!-- Hero Section -->
  <section class="section hero animate-in">
    <div class="hero-content">
      <h1 class="hero-title">
        Hi, I'm <span class="highlight">Sagar Dash</span><br/>
        Senior Software Engineer
      </h1>
      <p class="hero-tagline">
        Backend-focused engineer with 8+ years of experience scaling distributed systems.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Get in Touch</a>
        <a href="https://drive.google.com/file/d/1AMJCy47vP3bqVHn_gX5yRgyi_hZUmI-f/view" target="_blank" rel="noopener noreferrer" class="btn btn-outline">Download CV</a>
      </div>
    </div>
    <div class="hero-avatar">
      <div class="avatar-frame">
        <div class="avatar-img-container">
          <img src="/avatar.png" alt="Sagar Dash" class="avatar-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="section">
    <h2 class="section-title">About Me</h2>
    <div class="about-content">
      <AboutContent />
    </div>
  </section>

  <!-- Experience Section -->
  <section id="experience" class="section">
    <h2 class="section-title">Experience</h2>
    <div class="experience-list">
      
      {experienceWithContent.map(exp => (
        <div class="experience-item">
          <div class="experience-header">
            <div>
              <h3 class="experience-role">{exp.data.role}</h3>
              <p class="experience-company">{exp.data.company}</p>
            </div>
            <span class="experience-period">{exp.data.period}</span>
          </div>
          <div class="experience-desc experience-highlights">
            <exp.Content />
          </div>
        </div>
      ))}

    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="section">
    <h2 class="section-title">Skills</h2>
    <div class="skills-grid">
      
      {sortedSkills.map(category => (
        <div class="skill-category">
          <h3 class="category-title">{category.data.title}</h3>
          <div class="skill-tags">
            {category.data.skills.map(skill => (
              <span class="tag">{skill}</span>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>

  <!-- Open Source Section -->
  <section id="open-source" class="section">
    <h2 class="section-title">Open Source</h2>
    <div class="os-grid">
      
      {sortedOpenSource.map(project => (
        <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="os-card">
          <div class="os-header">
            <h3 class="os-title">{project.data.title}</h3>
            <span class={`os-role ${project.data.role.toLowerCase()}`}>{project.data.role}</span>
          </div>
          <p class="os-desc">{project.data.description}</p>
        </a>
      ))}

    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="section">
    <h2 class="section-title">Featured Projects</h2>
    <div class="projects-grid">
      {sortedProjects.length > 0 ? sortedProjects.map(project => (
        <a href={`/projects/${project.slug}`} class="project-card">
          {project.data.coverImage && (
            <img src={project.data.coverImage} alt={project.data.title} class="project-image" />
          )}
          <div class="project-info">
            <h3 class="project-title">{project.data.title}</h3>
            <p class="project-desc">{project.data.description}</p>
            <div class="project-tags">
              {project.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </a>
      )) : (
        <p>No projects found. Check back soon!</p>
      )}
    </div>
  </section>

  <!-- Articles Section -->
  <section id="articles" class="section">
    <h2 class="section-title">Latest Articles</h2>
    <p class="section-subtitle">Thoughts, opinions, and technical tutorials.</p>
    
    <div class="carousel-container">
      <div class="carousel-track" id="articles-carousel">
        {allArticles.map(article => (
          <div class="carousel-item">
            <a href={article.link} target="_blank" rel="noopener noreferrer" class="article-card-mini">
              <div class="article-meta-mini">
                <span class="source-tag-mini">{article.source}</span>
                <span class="read-time-mini">{article.readingTime}</span>
              </div>
              <h3 class="article-title-mini">{article.title}</h3>
              <time class="article-date-mini">
                {article.date.toLocaleDateString('en-US', {
                  month: 'short', day: 'numeric', year: 'numeric'
                })}
              </time>
            </a>
          </div>
        ))}
      </div>
      
      <div class="carousel-controls">
        <button class="carousel-btn prev" aria-label="Previous articles">&larr;</button>
        <button class="carousel-btn next" aria-label="Next articles">&rarr;</button>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section contact">
    <h2 class="section-title">Get in Touch</h2>
    <p>Feel free to reach out if you want to collaborate, ask a question, or simply say hello!</p>
    <div class="contact-methods">
      <a href="mailto:talk@sagardash.me" class="contact-method-link">
        <span class="method-icon">📩</span> talk@sagardash.me
      </a>
      <a href="https://t.me/sagardashme" target="_blank" rel="noopener noreferrer" class="contact-method-link">
        <span class="method-icon">✈️</span> Telegram
      </a>
      <a href="http://m.me/sagar.dash1" target="_blank" rel="noopener noreferrer" class="contact-method-link">
        <span class="method-icon">💬</span> Messenger
      </a>
    </div>
    
    <!-- Formspree Form -->
    <form class="contact-form" action="https://formspree.io/f/YOUR_FORMSPREE_ID" method="POST">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Your Name" />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="your.email@example.com" />
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" required placeholder="What's on your mind?"></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Send Message</button>
    </form>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    display: flex;
    align-items: center;
    gap: 3rem;
    min-height: 80vh;
  }
  .hero-content {
    flex: 1;
  }
  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .highlight {
    background: linear-gradient(135deg, var(--brand-color), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-tagline {
    font-size: 1.25rem;
    opacity: 0.8;
    margin: 1.5rem 0 2rem 0;
    max-width: 600px;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
  }
  .hero-avatar {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .avatar-frame {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    padding: 6px; /* Width of the gradient frame */
    background: linear-gradient(135deg, var(--brand-color), #8b5cf6, var(--brand-color));
    background-size: 200% 200%;
    animation: gradientMove 5s ease infinite;
    box-shadow: 0 20px 50px rgba(var(--brand-rgb), 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .avatar-frame:hover {
    transform: scale(1.02) translateY(-5px);
  }
  .avatar-img-container {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden; /* Ensures the image is strictly circular */
    border: 4px solid var(--bg-color);
    background: var(--bg-color);
  }
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @keyframes gradientMove {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Section Titles */
  .section-title {
    font-size: 2rem;
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
  }
  .section-title::after {
    content: '';
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    width: 60%;
    height: 4px;
    background: var(--brand-color);
    border-radius: 2px;
  }

  /* About */
  .about-content {
    font-size: 1.1rem;
    line-height: 1.8;
  }
  :global(.about-content ul) {
    margin-top: 1rem;
    padding-left: 1.5rem;
  }
  :global(.about-content li) {
    margin-bottom: 0.5rem;
  }

  /* Experience Timeline */
  .experience-list {
    position: relative;
    padding-left: 2rem;
  }
  .experience-list::before {
    content: '';
    position: absolute;
    top: 0;
    left: 8px; /* Centers the 2px line based on the dot size */
    bottom: 0;
    width: 2px;
    background: var(--border-color);
  }
  
  .experience-item {
    position: relative;
    padding-bottom: 3rem;
  }
  .experience-item:last-child {
    padding-bottom: 0;
  }
  .experience-item::before {
    content: '';
    position: absolute;
    left: -2rem; /* Exact offset needed relative to padding-left */
    top: 0.25rem;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-color);
    border: 3px solid var(--brand-color);
    z-index: 10;
    box-shadow: 0 0 0 4px var(--bg-color); /* Cut out background effectively */
  }
  
  .experience-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .experience-role {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }
  .experience-company {
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.9;
    font-weight: 500;
  }
  .experience-period {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--brand-color);
    opacity: 0.9;
  }
  .experience-desc {
    margin: 1rem 0 0 0;
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.8;
  }
  .experience-highlights {
    padding-left: 0;
    font-size: 0.95rem;
    opacity: 0.8;
    list-style-type: none; /* Custom bullets */
  }
  :global(.experience-highlights p) {
    margin-bottom: 0.5rem;
  }
  :global(.experience-highlights ul) {
    list-style: none;
    padding-left: 1.25rem;
  }
  :global(.experience-highlights li) {
    margin-bottom: 0.5rem;
    position: relative;
  }
  :global(.experience-highlights li::before) {
    content: '→';
    position: absolute;
    left: -1.25rem;
    color: var(--brand-color);
    opacity: 0.7;
  }

  /* Skills Grid */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .skill-category {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 2rem;
    height: 100%;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .skill-category:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: var(--brand-color);
  }
  .category-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-color);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .category-title::before {
    content: '';
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--brand-color);
  }
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: auto;
  }
  .skill-tags .tag {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .skill-tags .tag:hover {
    background: var(--text-color);
    color: var(--bg-color);
    border-color: var(--text-color);
  }

  /* Open Source Grid */
  .os-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .os-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    color: inherit;
  }
  .os-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--brand-color);
  }
  .os-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
    gap: 1rem;
  }
  .os-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.4;
  }
  .os-role {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 9999px;
    white-space: nowrap;
  }
  .os-role.author {
    background-color: rgba(0, 112, 243, 0.1);
    color: var(--brand-color);
    border: 1px solid rgba(0, 112, 243, 0.2);
  }
  .os-role.contributor {
    background-color: var(--bg-color);
    color: var(--text-color);
    border: 1px solid var(--border-color);
    opacity: 0.8;
  }
  .os-desc {
    font-size: 0.95rem;
    opacity: 0.8;
    margin: 0;
    flex-grow: 1;
  }

  /* Projects Grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 2rem;
  }
  .project-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
  }
  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow);
    border-color: var(--brand-color);
  }
  .project-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .project-info {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .project-title {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }
  .project-desc {
    opacity: 0.8;
    font-size: 0.95rem;
    flex: 1;
    margin-bottom: 1rem;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  /* Carousel Styles */
  .carousel-container {
    position: relative;
    margin-top: 2rem;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    scroll-behavior: smooth;
    padding: 1rem 0;
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
  }

  .carousel-track::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  .carousel-item {
    flex: 0 0 100%;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .carousel-item {
      flex: 0 0 calc(50% - 0.75rem);
    }
  }

  @media (min-width: 1200px) {
    .carousel-item {
      flex: 0 0 calc(25% - 1.125rem);
    }
  }

  .article-card-mini {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    transition: all 0.3s ease;
    text-decoration: none;
    color: var(--text-color);
  }

  .article-card-mini:hover {
    transform: translateY(-5px);
    border-color: var(--brand-color);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .article-meta-mini {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  .source-tag-mini {
    font-weight: 700;
    color: var(--brand-color);
    text-transform: uppercase;
  }

  .article-title-mini {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: auto;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-date-mini {
    font-size: 0.8rem;
    opacity: 0.6;
    margin-top: 1rem;
  }

  .carousel-controls {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .carousel-btn {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    color: var(--text-color);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    font-size: 1.2rem;
  }

  .carousel-btn:hover {
    background: var(--brand-color);
    color: white;
    border-color: var(--brand-color);
    transform: scale(1.1);
  }

  .section-subtitle {
    opacity: 0.7;
    margin-bottom: 2rem;
  }

  .contact-methods {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .contact-method-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--brand-color);
    padding: 0.6rem 1.25rem;
    background: rgba(var(--brand-rgb), 0.1);
    border-radius: 99px;
    transition: all 0.2s ease;
    text-decoration: none;
  }
  .contact-method-link:hover {
    transform: translateY(-2px);
    background: rgba(var(--brand-rgb), 0.2);
    box-shadow: 0 4px 12px rgba(var(--brand-rgb), 0.1);
  }
  .method-icon {
    font-size: 1.2rem;
  }

  /* Contact Form */
  .contact-form {
    background: var(--card-bg);
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid var(--border-color);
    margin-top: 2rem;
  }
  .form-group {
    margin-bottom: 1.5rem;
  }
  .form-group label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse;
      text-align: center;
      padding-top: 2rem;
    }
    .hero-actions {
      justify-content: center;
    }
    .avatar-placeholder {
      width: 200px;
      height: 200px;
    }
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Carousel Styles */
  .carousel-container {
    position: relative;
    margin-top: 2rem;
    overflow: hidden;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    scroll-behavior: smooth;
    padding: 1rem 0;
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
  }

  .carousel-track::-webkit-scrollbar {
    display: none; /* Chrome, Safari, Opera */
  }

  .carousel-item {
    flex: 0 0 100%;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .carousel-item {
      flex: 0 0 calc(50% - 0.75rem);
    }
  }

  @media (min-width: 1200px) {
    .carousel-item {
      flex: 0 0 calc(25% - 1.125rem);
    }
  }

  .article-card-mini {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    transition: all 0.3s ease;
    text-decoration: none;
    color: var(--text-color);
  }

  .article-card-mini:hover {
    transform: translateY(-5px);
    border-color: var(--brand-color);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .article-meta-mini {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  .source-tag-mini {
    font-weight: 700;
    color: var(--brand-color);
    text-transform: uppercase;
  }

  .article-title-mini {
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: auto;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-date-mini {
    font-size: 0.8rem;
    opacity: 0.6;
    margin-top: 1rem;
