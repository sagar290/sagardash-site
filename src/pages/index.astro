---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Content as AboutContent } from "../content/about.md";
import Parser from "rss-parser";
import Sparkles from "../components/ui/Sparkles.astro";
import MovingBorder from "../components/ui/MovingBorder.astro";
import HeroHighlight from "../components/ui/HeroHighlight.astro";
import MagicButton from "../components/ui/MagicButton.astro";

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allExperience = await getCollection("experience");
const sortedExperience = allExperience.sort(
  (a, b) => a.data.order - b.data.order
);
// Render markdown content for experience highlights
const experienceWithContent = await Promise.all(
  sortedExperience.map(async (entry) => {
    const { Content } = await entry.render();
    return { ...entry, Content };
  })
);

const allSkills = await getCollection("skills");
const sortedSkills = allSkills.sort((a, b) => a.data.order - b.data.order);

const allOpenSource = await getCollection("opensource");
const sortedOpenSource = allOpenSource.sort(
  (a, b) => a.data.order - b.data.order
);

// Fetch Articles
const localArticles = await getCollection("articles");
const MEDIUM_RSS_URL = "https://medium.com/feed/@sagar-dash290";
const parser = new Parser();
let mediumArticles: any[] = [];

try {
  const feed = await parser.parseURL(MEDIUM_RSS_URL);
  mediumArticles = feed.items.map((item) => {
    const wordCount = item["content:encoded"]?.split(/\s+/).length || 0;
    const readingTime = Math.ceil(wordCount / 200) || 1;
    return {
      title: item.title,
      link: item.link,
      date: new Date(item.pubDate!),
      readingTime: `${readingTime} min read`,
      source: "Medium",
    };
  });
} catch (error) {
  console.warn("Could not fetch medium articles during build.");
}

const allArticles = [
  ...localArticles.map((a) => ({
    title: a.data.title,
    link: a.data.link || `/articles/${a.slug}`,
    date: a.data.date,
    readingTime: "Local",
    source: "Local",
  })),
  ...mediumArticles,
].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<BaseLayout title="Sagar Dash | Backend Architect">
  <!-- Hero Section -->
  <HeroHighlight>
    <div class="container relative z-10 pt-8 md:pt-0">
      <div
        class="section hero animate-in flex flex-col md:flex-row items-center gap-12 lg:gap-20"
      >
        <div class="hero-content flex-1 text-left">
          <h1 class="hero-title leading-tight">
            Hi, I'm <span class="highlight">Sagar Dash</span><br />
            Backend Architect
          </h1>
          <div class="hero-specialties mt-4 flex flex-wrap gap-x-4 gap-y-2 text-sm font-medium tracking-wide opacity-70 uppercase">
             <span>APIs</span>
             <span class="bullet">•</span>
             <span>Microservices</span>
             <span class="bullet">•</span>
             <span>Distributed Systems</span>
             <span class="bullet">•</span>
             <span>Cloud Architecture</span>
          </div>
          <p class="hero-tagline max-w-xl">
            Backend-focused engineer with 8+ years of experience scaling
            distributed systems.
          </p>
          <div class="hero-actions mt-8 flex flex-wrap gap-4 relative z-20">
            <MagicButton href="#contact">Get in Touch</MagicButton>
            <MagicButton
              href="https://drive.google.com/file/d/1AMJCy47vP3bqVHn_gX5yRgyi_hZUmI-f/view"
              target="_blank"
              rel="noopener noreferrer">Download CV</MagicButton
            >
          </div>

          <div class="hero-socials mt-8 flex items-center gap-6 relative z-20">
            <a href="https://github.com/sagar290" target="_blank" rel="noopener noreferrer" class="social-icon-btn github-btn group" aria-label="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/sagardash1/" target="_blank" rel="noopener noreferrer" class="social-icon-btn linkedin-btn group" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-linkedin"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="https://medium.com/@sagar-dash290" target="_blank" rel="noopener noreferrer" class="social-icon-btn medium-btn group" aria-label="Medium">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-medium"><path d="M2.5 3h19c.3 0 .5.2.5.5v17c0 .3-.2.5-.5.5h-19a.5.5 0 0 1-.5-.5v-17c0-.3.2-.5.5-.5z"/><path d="M12 12m-3.5 0a3.5 3.5 0 1 0 7 0a3.5 3.5 0 1 0 -7 0"/><path d="M18 12c0 1.93-1.12 3.5-2.5 3.5s-2.5-1.57-2.5-3.5 1.12-3.5 2.5-3.5 2.5 1.57 2.5 3.5z"/><path d="M21 12c0 1.66-.22 3-.5 3s-.5-1.34-.5-3 .22-3 .5-3 .5 1.34.5 3z"/></svg>
            </a>
            <a href="https://x.com/Sagar290" target="_blank" rel="noopener noreferrer" class="social-icon-btn x-btn group" aria-label="X (Twitter)">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x-twitter"><path d="M4 4l11.7 16H20L8.3 4H4z"/><path d="m4 20 6.7-6.8m2.8-2.8L20 4"/></svg>
            </a>
          </div>
        </div>
        <div class="hero-avatar relative">
          <Sparkles particleColor="var(--brand-color)" size={8} />
          <div class="avatar-frame shrink-0">
            <div class="avatar-img-container">
              <img src="/avatar.png" alt="Sagar Dash" class="avatar-img" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </HeroHighlight>

  <!-- About Section -->
  <section id="about" class="section">
    <h2 class="section-title">About Me</h2>
    <div class="about-content">
      <AboutContent />
    </div>
  </section>

  <!-- Experience Section -->
  <section id="experience" class="section">
    <h2 class="section-title">Experience</h2>
    <div class="experience-list">
      {
        experienceWithContent.map((exp) => (
          <div class="experience-item">
            <div class="experience-header">
              <div>
                <h3 class="experience-role">{exp.data.role}</h3>
                <p class="experience-company">{exp.data.company}</p>
              </div>
              <span class="experience-period">{exp.data.period}</span>
            </div>
            <div class="experience-desc experience-highlights">
              <exp.Content />
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="section">
    <h2 class="section-title">Skills</h2>
    <div class="skills-grid">
      {
        sortedSkills.map((category) => (
          <div class="skill-category">
            <h3 class="category-title">{category.data.title}</h3>
            <div class="skill-tags">
              {category.data.skills.map((skill) => (
                <span class="tag">{skill}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Open Source Section -->
  <section id="open-source" class="section">
    <h2 class="section-title">Open Source</h2>
    <div class="os-grid">
      {
        sortedOpenSource.map((project) => (
          <a
            href={project.data.link}
            target="_blank"
            rel="noopener noreferrer"
            class="os-card"
          >
            <div class="os-header">
              <h3 class="os-title">{project.data.title}</h3>
              <span class={`os-role ${project.data.role.toLowerCase()}`}>
                {project.data.role}
              </span>
            </div>
            <p class="os-desc">{project.data.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="section">
    <h2 class="section-title">Featured Projects</h2>
    <div class="projects-grid">
      {
        sortedProjects.length > 0 ? (
          sortedProjects.map((project) => (
            <a href={`/projects/${project.slug}`} class="project-card">
              {project.data.coverImage && (
                <img
                  src={project.data.coverImage}
                  alt={project.data.title}
                  class="project-image"
                />
              )}
              <div class="project-info">
                <h3 class="project-title">{project.data.title}</h3>
                <p class="project-desc">{project.data.description}</p>
                <div class="project-tags">
                  {project.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))
        ) : (
          <p>No projects found. Check back soon!</p>
        )
      }
    </div>
  </section>

  <!-- Articles Section -->
  <section id="articles" class="section">
    <h2 class="section-title">Latest Articles</h2>
    <p class="section-subtitle">Th
        oughts, opinions, and technical tutorials.</
      p>

    <div class="carousel-container">
      <div class="carousel-track" id="articles-carousel">
        {
          allArticles.map((article) => (
            <div class="carousel-item">
              <a
                href={article.link}
                target="_blank"
                rel="noopener noreferrer"
                class="article-card-mini"
              >
                <div class="article-meta-mini">
                  <span class="source-tag-mini">{article.source}</span>
                  <span class="read-time-mini">{article.readingTime}</span>
                </div>
                <h3 class="article-title-mini">{article.title}</h3>
                <time class="article-date-mini">
                  {article.date.toLocaleDateString("en-US", {
                    month: "short",
                    day: "numeric",
                    year: "numeric",
                  })}
                </time>
              </a>
            </div>
          ))
        }
      </div>

      <div class="carousel-controls">
        <button class="carousel-btn prev" aria-label="Previous articles"
          >&larr;</button
        >
        <button class="carousel-btn next" aria-label="Next articles"
          >&rarr;</button
        >
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="section contact">
    <h2 class="section-title">Get in Touch</h2>
    <p>
      Feel free to reach out if you want to collaborate, ask a question, or
      simply say hello!
    </p>
    <div class="contact-methods">
      <a href="mailto:talk@sagardash.me" class="contact-method-link">
        <span class="method-icon">📩</span> talk@sagardash.me
      </a>
      <a
        href="https://t.me/sagardashme"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-method-link"
      >
        <span class="method-icon">✈️</span> Telegram
      </a>
      <a
        href="http://m.me/sagar.dash1"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-method-link"
      >
        <span class="method-icon">💬</span> Messenger
      </a>
    </div>

    <!-- Formspree Form -->
    <form
      class="contact-form"
      action="https://formspree.io/f/xreawpqj"
      method="POST"
    >
      <div class="form-group">
        <label for="name">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Your Name"
        />
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="your.email@example.com"
        />
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          placeholder="What's on your mind?"></textarea>
      </div>
      <MagicButton type="submit">Send Message</MagicButton>
    </form>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    display: flex;
    align-items: center;
    gap: 3rem;
    min-height: 80vh;
  }
  .hero-content {
    flex: 1;
  }
  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .highlight {
    background: linear-gradient(135deg, var(--brand-color), #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-tagline {
    font-size: 1.25rem;
    opacity: 0.8;
    margin: 1.5rem 0 2rem 0;
    max-width: 600px;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
  }
  .hero-socials {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .social-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(var(--brand-rgb), 0.05);
    border: 1px solid var(--border-color);
    color: var(--text-color);
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
  }
  .social-icon-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--btn-hover-bg, linear-gradient(135deg, var(--brand-color), #8b5cf6));
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }
  .social-icon-btn:hover {
    color: white !important;
    border-color: var(--btn-color);
    transform: translateY(-5px);
    box-shadow: 0 10px 20px var(--btn-glow);
  }

  .github-btn {
    --btn-color: #ffffff;
    --btn-hover-bg: #333;
    --btn-glow: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    background: rgba(255, 255, 255, 0.05);
  }
  .linkedin-btn {
    --btn-color: #0077b5;
    --btn-hover-bg: #0077b5;
    --btn-glow: rgba(0, 119, 181, 0.3);
    color: #0077b5;
    background: rgba(0, 119, 181, 0.1);
  }
  .medium-btn {
    --btn-color: #00ab6c;
    --btn-hover-bg: #00ab6c;
    --btn-glow: rgba(0, 171, 108, 0.3);
    color: #00ab6c;
    background: rgba(0, 171, 108, 0.1);
  }
  .x-btn {
    --btn-color: #ffffff;
    --btn-hover-bg: #000000;
    --btn-glow: rgba(255, 255, 255, 0.2);
    color: var(--text-color);
    background: rgba(var(--brand-rgb), 0.05);
  }

  .hero-specialties {
    color: var(--text-color);
  }

  .hero-specialties .bullet {
    color: var(--brand-color);
    font-weight: 900;
  }

  .social-icon-btn:hover::before {
    opacity: 1;
  }
  .social-icon-btn svg {
    width: 22px;
    height: 22px;
    transition: transform 0.3s ease;
  }
  .social-icon-btn:hover svg {
    transform: scale(1.1);
  }
  .hero-avatar {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .avatar-frame {
    width: 300px;
    height: 300px;
    border-radius: 50%;
    padding: 6px; /* Width of the gradient frame */
    background: linear-gradient(
      135deg,
      var(--brand-color),
      #8b5cf6,
      var(--brand-color)
    );
    background-size: 200% 200%;
    animation: gradientMove 5s ease infinite;
    box-shadow: 0 20px 50px rgba(var(--brand-rgb), 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .avatar-frame:hover {
    transform: scale(1.02) translateY(-5px);
  }
  .avatar-img-container {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden; /* Ensures the image is strictly circular */
    border: 4px solid var(--bg-color);
    background: var(--bg-color);
  }
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @keyframes gradientMove {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  /* Section Titles */
  .section-title {
    font-size: 2rem;
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
  }
  .section-title::after {
    content: "";
    position: absolute;
    bottom: -0.5rem;
    left: 0;
    width: 60%;
    height: 4px;
    background: var(--brand-color);
    border-radius: 2px;
  }

  /* About */
  .about-content {
    font-size: 1.1rem;
    line-height: 1.8;
  }
  :global(.about-content ul) {
    margin-top: 1rem;
    padding-left: 1.5rem;
  }
  :global(.about-content li) {
    margin-bottom: 0.5rem;
  }

  /* Experience Timeline */
  .experience-list {
    position: relative;
    padding-left: 2rem;
  }
  .experience-list::before {
    content: "";
    position: absolute;
    top: 0;
    left: 8px; /* Centers the 2px line based on the dot size */
    bottom: 0;
    width: 2px;
    background: var(--border-color);
  }

  .experience-item {
    position: relative;
    padding-bottom: 3rem;
  }
  .experience-item:last-child {
    padding-bottom: 0;
  }
  .experience-item::before {
    content: "";
    position: absolute;
    left: -2rem; /* Exact offset needed relative to padding-left */
    top: 0.25rem;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--bg-color);
    border: 3px solid var(--brand-color);
    z-index: 10;
    box-shadow: 0 0 0 4px var(--bg-color); /* Cut out background effectively */
  }

  .experience-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .experience-role {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }
  .experience-company {
    font-size: 1rem;
    color: var(--text-color);
    opacity: 0.9;
    font-weight: 500;
  }
  .experience-period {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--brand-color);
    opacity: 0.9;
  }
  .experience-desc {
    margin: 1rem 0 0 0;
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.8;
  }
  .experience-highlights {
    padding-left: 0;
    font-size: 0.95rem;
    opacity: 0.8;
    list-style-type: none; /* Custom bullets */
  }
  :global(.experience-highlights p) {
    margin-bottom: 0.5rem;
  }
  :global(.experience-highlights ul) {
    list-style: none;
    padding-left: 1.25rem;
  }
  :global(.experience-highlights li) {
    margin-bottom: 0.5rem;
    position: relative;
  }
  :global(.experience-highlights li::before) {
    content: "→";
    position: absolute;
    left: -1.25rem;
    color: var(--brand-color);
    opacity: 0.7;
  }

  /* Skills Grid */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .skill-category {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 2rem;
    height: 100%;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }
  .skill-category:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: var(--brand-color);
  }
  .category-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-color);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .category-title::before {
    content: "";
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--brand-color);
  }
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: auto;
  }
  .skill-tags .tag {
    background: var(--bg-color);
    border: 1px solid var(--border-color);
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .skill-tags .tag:hover {
    background: var(--text-color);
    color: var(--bg-color);
    border-color: var(--text-color);
  }

  /* Open Source Grid */
  .os-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .os-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    color: inherit;
  }
  .os-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--brand-color);
  }
  .os-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
    gap: 1rem;
  }
